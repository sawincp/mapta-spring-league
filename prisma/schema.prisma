model Profile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  phoneNumber String?
  address     String?
  city        String?
  state       String?
  zipCode     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model Location {
  id             Int      @id @default(autoincrement())
  name           String
  address        String
  numberOfCourts Int
  comments       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  divisions Division[]
  users     User[]
}

model Division {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations Location[]
  users     User[]
}
